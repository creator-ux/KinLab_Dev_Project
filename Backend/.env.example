## Backend environment variables

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Security
JWT_SECRET=change_this_in_production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging
# Habilita modo silencioso de dotenv para evitar tips/emojis en consola
DOTENV_CONFIG_QUIET=true

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3307
DB_NAME=laboratorios_db2
DB_USER=root
DB_PASSWORD=your_db_password
DB_CONN_LIMIT=15